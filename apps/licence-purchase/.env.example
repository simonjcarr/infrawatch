# ──────────────────────────────────────────────────────────────────────────────
# Infrawatch — Licence Purchase App (.env.example)
# Copy this file to `.env.local` and fill in real values for local development.
# Never commit real secrets to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ── Database (independent Postgres; not shared with apps/web) ─────────────────
DATABASE_URL=postgres://infrawatch:infrawatch@localhost:5433/licence_purchase

# ── Better Auth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3001

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Products, tiers and prices are managed in Stripe and synced into our DB via
# the catalog sync job. Each Stripe Product must carry these metadata keys:
#   carrtech_product        slug of the CarrTech.dev product (e.g. `ct-ops`)
#   carrtech_product_name   human name of the product (e.g. `CT-Ops`)
#   tier                    tier slug within the product (e.g. `pro`)
#   tier_order              integer ordering within the product
#   features                JSON array of feature keys (e.g. `["ssoOidc"]`)
# Run `pnpm tsx apps/licence-purchase/scripts/sync-stripe-catalog.ts` to sync.

# Comma-separated list of enabled payment methods on Stripe Checkout.
# card        = credit / debit card (global)
# bacs_debit  = BACS Direct Debit (UK only, GBP only, 3-day settlement)
STRIPE_PAYMENT_METHODS=card,bacs_debit

# Days to give the customer to pay an invoice when purchase is "pay by invoice"
# (Stripe subscription collection_method=send_invoice + bank transfer).
STRIPE_INVOICE_COLLECTION_DAYS=14

# Stripe Tax automatic calculation (set to false if you handle VAT manually).
STRIPE_TAX_ENABLED=true

# ── Licence signing (RS256) ───────────────────────────────────────────────────
# The licence signing private key must match the public key in apps/web/lib/licence.ts.
# Provide either the PEM inline (escape newlines as \n) OR a path to a file.
# LICENCE_SIGNING_PRIVATE_KEY_PEM takes precedence if both are set.
LICENCE_SIGNING_PRIVATE_KEY_PEM=
LICENCE_SIGNING_PRIVATE_KEY_PATH=../../deploy/scripts/licence-dev-private.pem

# These two must match apps/web/lib/licence.ts exactly.
LICENCE_ISSUER=licence.infrawatch.io
LICENCE_AUDIENCE=install.infrawatch.io

# Default term lengths for issued licences. Buffer days are added so a late
# payment retry doesn't instantly revoke a just-issued key.
LICENCE_MONTHLY_DAYS=35
LICENCE_YEARLY_DAYS=375

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Used for transactional email: receipts, payment failures, renewal reminders,
# and "your licence is ready, log in to download" notifications.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@infrawatch.io
SMTP_FROM_NAME=Infrawatch Licensing

# Internal ops email for new-purchase / failed-payment notifications.
OPS_NOTIFICATION_EMAIL=ops@infrawatch.io

# ── Public links (footer, emails) ─────────────────────────────────────────────
SUPPORT_EMAIL=support@infrawatch.io
TERMS_URL=https://infrawatch.io/terms
PRIVACY_URL=https://infrawatch.io/privacy

# ── Support portal / AI triage ────────────────────────────────────────────────
# The support portal lets customers raise tickets; Claude drafts the first reply
# with read-only GitHub access, and staff can join at any time. See
# apps/docs/docs/features/support-portal.md and architecture/support-ai.md.

# Anthropic API key — required for AI triage. Without it the kill switch
# effectively fails open (tickets queue for staff but no AI reply is produced).
ANTHROPIC_API_KEY=

# Hard kill switch. Set to 1 to force-disable AI regardless of the DB toggle.
# Use this for operational emergencies (leaked key, runaway cost, etc).
SUPPORT_AI_KILL_SWITCH=0

# Models. Defaults match current generation; override only if you need to pin.
SUPPORT_AI_MODEL_ID=claude-sonnet-4-6
SUPPORT_AI_MODERATION_MODEL_ID=claude-haiku-4-5

# GitHub repo the AI can read via search_code / read_file tools. Use a
# fine-grained PAT with Contents:read on this repo only — no write scopes.
SUPPORT_GITHUB_REPO=carrtech-dev/ct-ops
GITHUB_SUPPORT_READONLY_TOKEN=

# Optional comma-separated glob patterns. Any tool call whose path matches is
# rejected before the HTTP call to GitHub. Leave empty to allow the whole repo.
# Example: apps/web/enterprise/customer-list/**,secrets/**
SUPPORT_GITHUB_REPO_BLOCKLIST=

# Rolling-hour cap of AI responses per ticket. Hitting the cap pauses the ticket.
SUPPORT_AI_MAX_RESPONSES_PER_HOUR=10

# Worker poll interval in ms. Start the worker with: pnpm support:worker
SUPPORT_WORKER_POLL_MS=2000
