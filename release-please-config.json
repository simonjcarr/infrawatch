{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "bootstrap-sha": "3a07f49955814e7b8c949d50cc462c54fd060dff",
  "packages": {
    ".": {
      "release-type": "simple",
      "component": "bundle",
      "tag-separator": "/",
      "include-component-in-tag": true,
      "changelog-path": "deploy/customer-bundle/CHANGELOG.md",
      "exclude-paths": [
        "agent",
        "apps/docs",
        "docs"
      ]
    },
    "agent": {
      "release-type": "simple",
      "component": "agent",
      "tag-separator": "/",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    },
    "apps/web": {
      "release-type": "node",
      "component": "web",
      "tag-separator": "/",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    },
    "apps/ingest": {
      "release-type": "simple",
      "component": "ingest",
      "tag-separator": "/",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    },
    "apps/ansible-api": {
      "release-type": "simple",
      "component": "ansible-api",
      "tag-separator": "/",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    }
  }
}
