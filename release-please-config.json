{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "agent": {
      "release-type": "simple",
      "component": "agent",
      "tag-separator": "/",
      "include-component-in-tag": true,
      "changelog-path": "agent/CHANGELOG.md"
    },
    "apps/web": {
      "release-type": "node",
      "component": "web",
      "tag-separator": "/",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    },
    "apps/ingest": {
      "release-type": "simple",
      "component": "ingest",
      "tag-separator": "/",
      "include-component-in-tag": true,
      "changelog-path": "apps/ingest/CHANGELOG.md"
    }
  }
}
